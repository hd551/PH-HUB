-- ==================== نظام AI متقدم لتحليل الخريطة وإعطاء تنبيهات ذكية ====================
task.spawn(function()
    task.wait(2)
    -- تحليل حجم الخريطة
    local function analyzeMap()
        local mapSize = 0
        local terrain = workspace:FindFirstChild("Terrain")
        if terrain then
            local size = terrain.Size
            mapSize = size.X + size.Z
        else
            -- تقدير حجم الخريطة من الأجزاء
            local partsCount = 0
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") and v.Size.Magnitude > 10 then
                    partsCount = partsCount + 1
                end
            end
            mapSize = partsCount
        end
        
        if mapSize > 5000 or mapSize > 200 then
            showNotification("🗺️ Large map detected! Speed recommended.", 3)
        elseif mapSize < 2000 then
            showNotification("✅ Small map - Hitbox extender will be very effective!", 3)
        else
            showNotification("🌍 Normal map - All features ready.", 2)
        end
        
        -- كشف نوع اللعبة من خلال وجود أجزاء معينة
        if workspace:FindFirstChild("Lobby") or workspace:FindFirstChild("WaitingRoom") then
            showNotification("⏳ Lobby area - Teleport will work after game starts.", 3)
        end
    end
    
    analyzeMap()
    
    -- تنبيهات دورية
    while true do
        task.wait(45)
        if espEnabled and #espNameTags == 0 then
            showNotification("💡 Tip: Enable ESP to see players through walls", 2.5)
        end
        if not speedEnabled and humanoid.WalkSpeed <= 16 then
            showNotification("⚡ Tip: Use Speed Control to move faster", 2.5)
        end
        if not hitboxEnabled then
            showNotification("📦 Tip: Hitbox Extender makes enemies easier to hit", 2.5)
        end
    end
end)


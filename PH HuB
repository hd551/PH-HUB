-- ==================== Hitbox (تضخيم كامل الجسم) ====================
local hitOn = false
local hitSize = 8

local function applyHitbox(plr)
    if not hitOn then return end
    if plr == player or ignoredPlayers[plr.Name] then return end
    local char = plr.Character
    if not char then return end
    -- قائمة بكل الأجزاء المهمة في أي لعبة
    local partsToScale = {
        "HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso",
        "Head", "Right Arm", "Left Arm", "Right Leg", "Left Leg"
    }
    for _, name in pairs(partsToScale) do
        local part = char:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            pcall(function()
                part.Size = Vector3.new(hitSize, hitSize, hitSize)
                part.Transparency = 0.4
                part.CanCollide = false
            end)
        end
    end
end

RunService.Heartbeat:Connect(function()
    if hitOn then
        for _, plr in pairs(Players:GetPlayers()) do
            pcall(applyHitbox, plr)
        end
    end
end)


-- دالة الفحص الأمني (تشتغل تلقائياً في الخلفية)
local function analyzeMap()
    local warnings = {}
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")

    -- 1. سرعة المشي الافتراضية
    if hum then
        if hum.WalkSpeed ~= 16 and not settings.speedEnabled then
            table.insert(warnings, "⚠️ السرعة الافتراضية متغيرة – قد يكون هناك كشف للسرعة.")
        end
    end

    -- 2. حجم الهيت بوكس
    if root and not settings.hbEnabled then
        if root.Size ~= Vector3.new(2,2,1) then
            table.insert(warnings, "⚠️ حجم الهيت بوكس متغير – قد يكون هناك كشف للهيت بوكس.")
        end
    end

    -- 3. ألعاب معروفة بحماية قوية
    local placeId = game.PlaceId
    local knownACGames = {
        [62845836] = "Arsenal",
        [6872274481] = "BedWars",
        [301549746] = "Counter Blox",
    }
    if knownACGames[placeId] then
        table.insert(warnings, "🛡️ هذه اللعبة معروفة بحماية قوية ضد الهاكات.")
    end

    -- 4. فحص أجزاء AntiCheat في workspace
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower():find("anticheat") then
            table.insert(warnings, "🛡️ تم العثور على أجزاء AntiCheat في الماب.")
            break
        end
    end

    -- عرض الحالة في التبويب
    if #warnings == 0 then
        securityStatus.Text = "✅ الأمان: لم يتم اكتشاف أي تهديدات.\n\nيمكنك تفعيل الميزات بأمان."
    else
        securityStatus.Text = "تحذيرات الأمان:\n\n" .. table.concat(warnings, "\n")
        -- إشعار أعلى الشاشة
        showNotification("⚠️ توجد تحذيرات أمان، راجع تبويب AI", Color3.fromRGB(255, 100, 100))
    end
end


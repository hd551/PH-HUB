-- 🧹 دوال مساعدة لنظام ESP (بدون خطوط)
-- ============================================================
local function ClearESP()
    for _, obj in pairs(Settings.ESPObjects.Names) do pcall(function() obj:Destroy() end) end
    for _, obj in pairs(Settings.ESPObjects.HealthBars) do pcall(function() obj:Destroy() end) end
    Settings.ESPObjects.Names = {}
    Settings.ESPObjects.HealthBars = {}
end

local function UpdateESP()
    if not Settings.ESPEnabled then ClearESP() return end
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and not Settings.IgnoredPlayers[p.Name] and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.2, 0))
                if onScreen and pos.Z > 0 then
                    -- اسم اللاعب على شكل [اسم]
                    if not Settings.ESPObjects.Names[p] then
                        local nameTag = Instance.new("TextLabel")
                        nameTag.Size = UDim2.new(0, 150, 0, 22)
                        nameTag.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                        nameTag.BackgroundTransparency = 0.5
                        nameTag.TextColor3 = Color3.fromRGB(255, 255, 255)
                        nameTag.TextSize = 12
                        nameTag.Font = Enum.Font.GothamBold
                        nameTag.Parent = screenGui
                        Instance.new("UICorner", nameTag).CornerRadius = UDim.new(0, 4)
                        Settings.ESPObjects.Names[p] = nameTag
                    end
                    Settings.ESPObjects.Names[p].Text = "[" .. p.Name .. "]"
                    Settings.ESPObjects.Names[p].Position = UDim2.new(0, pos.X - 75, 0, pos.Y - 42)
                    Settings.ESPObjects.Names[p].Visible = true
                    
                    -- شريط الصحة
                    if not Settings.ESPObjects.HealthBars[p] then
                        local bar = Instance.new("Frame")
                        bar.Size = UDim2.new(0, 65, 0, 6)
                        bar.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
                        bar.BorderSizePixel = 0
                        bar.Parent = screenGui
                        Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
                        Settings.ESPObjects.HealthBars[p] = bar
                    end
                    local healthPercent = hum.Health / hum.MaxHealth
                    local barWidth = 65 * healthPercent
                    Settings.ESPObjects.HealthBars[p].Size = UDim2.new(0, barWidth, 0, 6)
                    Settings.ESPObjects.HealthBars[p].Position = UDim2.new(0, pos.X - 32, 0, pos.Y - 20)
                    Settings.ESPObjects.HealthBars[p].BackgroundColor3 = Color3.fromRGB(0, 200, 0):Lerp(Color3.fromRGB(200, 0, 0), 1 - healthPercent)
                    Settings.ESPObjects.HealthBars[p].Visible = true
                else
                    if Settings.ESPObjects.Names[p] then Settings.ESPObjects.Names[p].Visible = false end
                    if Settings.ESPObjects.HealthBars[p] then Settings.ESPObjects.HealthBars[p].Visible = false end
                end
            else
                if Settings.ESPObjects.Names[p] then pcall(function() Settings.ESPObjects.Names[p]:Destroy() end); Settings.ESPObjects.Names[p] = nil end
                if Settings.ESPObjects.HealthBars[p] then pcall(function() Settings.ESPObjects.HealthBars[p]:Destroy() end); Settings.ESPObjects.HealthBars[p] = nil end
            end
        else
            if Settings.ESPObjects.Names[p] then pcall(function() Settings.ESPObjects.Names[p]:Destroy() end); Settings.ESPObjects.Names[p] = nil end
            if Settings.ESPObjects.HealthBars[p] then pcall(function() Settings.ESPObjects.HealthBars[p]:Destroy() end); Settings.ESPObjects.HealthBars[p] = nil end
        end
    end
end


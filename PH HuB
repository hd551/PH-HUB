            ShowNotification("⚡ السرعة مضبوطة: " .. Settings.SpeedValue, Color3.fromRGB(0, 200, 255))
        else
            ShowNotification("⚠️ السرعة غير صالحة (16-250)", Color3.fromRGB(200, 0, 0))
        end
    end
    speedInputBox.Visible = false
end)


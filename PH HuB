-- ==================== Teleport (الزر المنفصل) ====================
local teleportFeatureActive = false

-- دالة الحصول على موقع يد الخصم (أو أقرب نقطة)
local function getTeleportPosition(target)
    local char = target.Character
    if not char then return nil end
    local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm") or char:FindFirstChild("ArmR")
    if hand then return hand.Position end
    local head = char:FindFirstChild("Head")
    if head then return head.Position + Vector3.new(1.2, 0, 0) end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position + Vector3.new(1.5, 1, 0) end
    return nil
end

local function performTeleport()
    if isTeleporting then return end
    local target = getClosestTarget()
    if not target then
        tpFloatingBtn.Text = "❌"
        tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(0.6)
        tpFloatingBtn.Text = "🔮\nTP"
        tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        return
    end
    
    local teleportPos = getTeleportPosition(target)
    if not teleportPos then return end
    
    isTeleporting = true
    savedPosition = rootPart.CFrame
    
    -- الانتقال الفوري إلى موقع اليد
    rootPart.CFrame = CFrame.new(teleportPos)
    tpFloatingBtn.Text = "🔄"
    tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
    
    -- اللف حول الخصم (دورة سريعة)
    for angle = 0, 300, 60 do
        local rad = math.rad(angle)
        local offset = Vector3.new(math.cos(rad) * 2.2, 0, math.sin(rad) * 2.2)
        local newPos = teleportPos + offset
        pcall(function() rootPart.CFrame = CFrame.new(newPos, teleportPos) end)
        task.wait(0.012)
    end
    
    -- العودة إلى المكان الأصلي
    tpFloatingBtn.Text = "📍"
    tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    task.wait(0.08)
    if savedPosition then
        rootPart.CFrame = savedPosition
        savedPosition = nil
    end
    
    tpFloatingBtn.Text = "🔮\nTP"
    tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    isTeleporting = false
end


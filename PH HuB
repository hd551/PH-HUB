-- ==================== Aimlock المؤقت (بالضغط على الزر) ====================
local aimlockActive = false
local aimlockDuration = 0.8   -- مدة التصويب التلقائي عند الضغط

-- دالة الحصول على أقرب لاعب (مع تجاهل المتجاهلين)
local function getClosestTarget()
    local closest = nil
    local closestDist = 80
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and not ignoredPlayers[plr.Name] and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp and rootPart then
                local dist = (rootPart.Position - hrp.Position).Magnitude
                if dist < closestDist then
                    closestDist = dist
                    closest = plr
                end
            end
        end
    end
    return closest
end

-- وظيفة التصويب (توجيه الكاميرا واللاعب نحو الهدف)
local function lockOntoTarget(target)
    if not target or not target.Character then return end
    local targetPart = target.Character:FindFirstChild("HumanoidRootPart")
    if not targetPart then return end
    local targetPos = targetPart.Position
    -- توجيه الكاميرا بسلاسة
    local newCamCF = CFrame.new(Camera.CFrame.Position, targetPos)
    Camera.CFrame = newCamCF
    -- توجيه جسم اللاعب
    rootPart.CFrame = CFrame.new(rootPart.Position, Vector3.new(targetPos.X, rootPart.Position.Y, targetPos.Z))
end

-- عند الضغط على زر التصويب
aimlockBtn.MouseButton1Click:Connect(function()
    local target = getClosestTarget()
    if target then
        lockOntoTarget(target)
        -- إشارة بصرية
        aimlockBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
        task.wait(0.2)
        aimlockBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 0)
    else
        aimlockBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(0.2)
        aimlockBtn.BackgroundColor3 = Color3.fromRGB(200, 80, 0)
    end
end)

-- ==================== التلبورت (الزر المنفصل) ====================
local teleportEnabled = false

local function getTeleportPosition(target)
    local char = target.Character
    if not char then return nil end
    local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm") or char:FindFirstChild("ArmR")
    if hand then return hand.Position end
    local head = char:FindFirstChild("Head")
    if head then return head.Position + Vector3.new(1.2, 0, 0) end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position + Vector3.new(1.5, 1, 0) end
    return nil
end

local function performTeleport()
    if isTeleporting then return end
    local target = getClosestTarget()
    if not target then
        tpFloatingBtn.Text = "❌"
        tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(0.6)
        tpFloatingBtn.Text = "🔮\nTP"
        tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        return
    end
    
    local pos = getTeleportPosition(target)
    if not pos then return end
    
    isTeleporting = true
    savedPosition = rootPart.CFrame
    rootPart.CFrame = CFrame.new(pos)
    tpFloatingBtn.Text = "🔄"
    tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
    
    -- دورة حول اللاعب
    for ang = 0, 300, 60 do
        local rad = math.rad(ang)
        local offset = Vector3.new(math.cos(rad) * 2.2, 0, math.sin(rad) * 2.2)
        pcall(function() rootPart.CFrame = CFrame.new(pos + offset, pos) end)
        task.wait(0.012)
    end
    
    tpFloatingBtn.Text = "📍"
    tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    task.wait(0.08)
    if savedPosition then
        rootPart.CFrame = savedPosition
        savedPosition = nil
    end
    
    tpFloatingBtn.Text = "🔮\nTP"
    tpFloatingBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    isTeleporting = false
end


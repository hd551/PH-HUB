-- 🧠 نظام مراقبة الكومبو والـ Cooldown الذكي
-- ============================================================
local ComboTracker = {LastAction = 0, Count = 0}
local function CheckCombo(actionName)
    local now = tick()
    if now - ComboTracker.LastAction < 1.5 then
        ComboTracker.Count = ComboTracker.Count + 1
    else
        ComboTracker.Count = 1
    end
    ComboTracker.LastAction = now
    
    if ComboTracker.Count >= 4 then
        ShowNotification("⚠️ تنبيه: تستخدم " .. actionName .. " بسرعة كبيرة! انتظر قليلاً", Color3.fromRGB(255, 100, 0))
        return false
    end
    return true
end


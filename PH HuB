-- ==================== ESP محسّن (بدون تجمّد أبداً) ====================
local espEnabled = false
local espElements = {}   -- { [player] = {name, bar} }

local function destroyESPForPlayer(plr)
    local data = espElements[plr]
    if data then
        if data.name then pcall(function() data.name:Destroy() end) end
        if data.bar then pcall(function() data.bar:Destroy() end) end
        espElements[plr] = nil
    end
end

local function clearAllESP()
    for plr, _ in pairs(espElements) do
        destroyESPForPlayer(plr)
    end
    espElements = {}
end

local function updateESP()
    if not espEnabled then
        clearAllESP()
        return
    end
    
    local viewport = Camera.ViewportSize
    local centerX = viewport.X / 2
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == player or ignoredPlayers[plr.Name] then
            if espElements[plr] then destroyESPForPlayer(plr) end
            continue
        end
        
        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        
        if hrp and hum and hum.Health > 0 then
            local screenPos, onScreen = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.2, 0))
            
            if onScreen and screenPos.Z > 0 then
                -- إنشاء العناصر إذا لم تكن موجودة
                if not espElements[plr] then
                    local nameTag = Instance.new("TextLabel")
                    nameTag.Size = UDim2.new(0, 160, 0, 24)
                    nameTag.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                    nameTag.BackgroundTransparency = 0.5
                    nameTag.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameTag.TextSize = 12
                    nameTag.Font = Enum.Font.GothamBold
                    nameTag.Parent = screenGui
                    Instance.new("UICorner", nameTag).CornerRadius = UDim.new(0, 6)
                    
                    local healthBar = Instance.new("Frame")
                    healthBar.Size = UDim2.new(0, 70, 0, 6)
                    healthBar.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
                    healthBar.BorderSizePixel = 0
                    healthBar.Parent = screenGui
                    Instance.new("UICorner", healthBar).CornerRadius = UDim.new(1, 0)
                    
                    espElements[plr] = {name = nameTag, bar = healthBar}
                end
                
                local healthPercent = hum.Health / hum.MaxHealth
                local barWidth = 70 * healthPercent
                local x = screenPos.X - 80
                local y = screenPos.Y - 45
                
                espElements[plr].name.Position = UDim2.new(0, x, 0, y)
                espElements[plr].name.Text = "[" .. plr.Name .. "]"
                espElements[plr].name.Visible = true
                
                espElements[plr].bar.Size = UDim2.new(0, barWidth, 0, 6)
                espElements[plr].bar.Position = UDim2.new(0, screenPos.X - 35, 0, screenPos.Y - 20)
                espElements[plr].bar.BackgroundColor3 = Color3.fromRGB(0, 255, 0):Lerp(Color3.fromRGB(255, 0, 0), 1 - healthPercent)
                espElements[plr].bar.Visible = true
            else
                if espElements[plr] then
                    espElements[plr].name.Visible = false
                    espElements[plr].bar.Visible = false
                end
            end
        else
            -- اللاعب غير موجود أو مات => حذف ESP
            if espElements[plr] then
                destroyESPForPlayer(plr)
            end
        end
    end
end


-- ==================== ESP (أسماء + شريط صحة) بدون خطوط ====================
local espEnabled = false
local espNameTags = {}
local espHealthBars = {}

local function clearESP()
    for _, obj in pairs(espNameTags) do pcall(function() obj:Destroy() end) end
    for _, obj in pairs(espHealthBars) do pcall(function() obj:Destroy() end) end
    espNameTags = {}
    espHealthBars = {}
end

local function updateESP()
    if not espEnabled then clearESP() return end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and not ignoredPlayers[plr.Name] and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.2, 0))
                if onScreen and pos.Z > 0 then
                    -- اسم اللاعب بين قوسين
                    if not espNameTags[plr] then
                        local tag = Instance.new("TextLabel")
                        tag.Size = UDim2.new(0, 160, 0, 24)
                        tag.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                        tag.BackgroundTransparency = 0.5
                        tag.TextColor3 = Color3.fromRGB(255, 255, 255)
                        tag.TextSize = 12
                        tag.Font = Enum.Font.GothamBold
                        tag.Parent = screenGui
                        Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 6)
                        espNameTags[plr] = tag
                    end
                    espNameTags[plr].Text = "[" .. plr.Name .. "]"
                    espNameTags[plr].Position = UDim2.new(0, pos.X - 80, 0, pos.Y - 45)
                    espNameTags[plr].Visible = true
                    
                    -- شريط الصحة
                    if not espHealthBars[plr] then
                        local bar = Instance.new("Frame")
                        bar.Size = UDim2.new(0, 70, 0, 6)
                        bar.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
                        bar.BorderSizePixel = 0
                        bar.Parent = screenGui
                        Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
                        espHealthBars[plr] = bar
                    end
                    local healthPercent = hum.Health / hum.MaxHealth
                    local barWidth = 70 * healthPercent
                    espHealthBars[plr].Size = UDim2.new(0, barWidth, 0, 6)
                    espHealthBars[plr].Position = UDim2.new(0, pos.X - 35, 0, pos.Y - 20)
                    espHealthBars[plr].BackgroundColor3 = Color3.fromRGB(0, 255, 0):Lerp(Color3.fromRGB(255, 0, 0), 1 - healthPercent)
                    espHealthBars[plr].Visible = true
                else
                    if espNameTags[plr] then espNameTags[plr].Visible = false end
                    if espHealthBars[plr] then espHealthBars[plr].Visible = false end
                end
            else
                if espNameTags[plr] then espNameTags[plr]:Destroy() espNameTags[plr] = nil end
                if espHealthBars[plr] then espHealthBars[plr]:Destroy() espHealthBars[plr] = nil end
            end
        end
    end
end


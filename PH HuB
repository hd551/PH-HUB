-- ==================== Homing: الرصاص يذهب إلى أقرب لاعب ====================
local homingOn = false
local tracked = {}   -- لمنع إعادة التوجيه المتكرر لنفس المقذوف

local function getClosestEnemyPosition()
    local bestPos = nil
    local bestDist = 200
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= player and not ignoredPlayers[plr.Name] and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (rootPart.Position - hrp.Position).Magnitude
                if dist < bestDist then
                    bestDist = dist
                    bestPos = hrp.Position
                end
            end
        end
    end
    return bestPos
end

local function steerProjectile(proj, targetPos)
    if not proj or not proj.Parent then return end
    if proj:IsA("BasePart") and proj.Velocity then
        local dir = (targetPos - proj.Position).Unit
        local speed = proj.Velocity.Magnitude
        if speed < 20 then speed = 100 end   -- سرعة افتراضية للقذائف البطيئة
        proj.Velocity = dir * speed
        proj.CFrame = CFrame.new(proj.Position, targetPos)
    end
end

-- البحث عن المقذوفات وتوجيهها (خفيف جداً)
RunService.Heartbeat:Connect(function()
    if not homingOn then return end
    local targetPos = getClosestEnemyPosition()
    if not targetPos then return end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Velocity and obj.Velocity.Magnitude > 30 then
            if not obj:IsDescendantOf(character) and not tracked[obj] then
                tracked[obj] = true
                task.spawn(function()
                    task.wait(0.05)  -- ننتظر قليلاً بعد الإطلاق
                    if obj and obj.Parent then
                        steerProjectile(obj, targetPos)
                    end
                    tracked[obj] = nil
                end)
            end
        end
    end
end)


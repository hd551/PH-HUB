local hitboxOn = false
local hbSize = 8
local function applyHitbox(plr)
    if not hitboxOn then return end
    if plr == player or ignored[plr.Name] then return end
    local c = plr.Character
    if not c then return end
    local parts = {"HumanoidRootPart","Torso","UpperTorso","LowerTorso","Head","Right Arm","Left Arm","Right Leg","Left Leg"}
    for _,name in pairs(parts) do
        local p = c:FindFirstChild(name)
        if p and p:IsA("BasePart") then
            pcall(function() p.Size = Vector3.new(hbSize,hbSize,hbSize) p.Transparency = 0.4 p.CanCollide = false end)
        end
    end
end
RunService.Heartbeat:Connect(function()
    if hitboxOn then for _,plr in pairs(Players:GetPlayers()) do pcall(applyHitbox,plr) end end
end)

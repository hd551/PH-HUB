local function ApplyHitboxToPlayer(pl)
    if not Settings.HitboxEnabled then return end
    if pl == player or Settings.IgnoredPlayers[pl.Name] then return end
    local char = pl.Character
    if not char then return end
    local parts = {char:FindFirstChild("HumanoidRootPart"), char:FindFirstChild("Torso"), char:FindFirstChild("UpperTorso")}
    for _, part in pairs(parts) do
        if part then
            part.Size = Vector3.new(Settings.HitboxSize, Settings.HitboxSize, Settings.HitboxSize)
            part.Transparency = 0.4
            part.CanCollide = false
        end
    end
end


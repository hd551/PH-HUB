print("Part2 loaded")local homingOn = false
local function getClosestEnemyPos()
    local bestPos,bestDist = nil,200
    for _,plr in pairs(Players:GetPlayers()) do
        if plr~=player and not ignored[plr.Name] and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (rootPart.Position - hrp.Position).Magnitude
                if dist < bestDist then bestDist=dist bestPos=hrp.Position end
            end
        end
    end
    return bestPos
end
local function steerProjectile(proj,targetPos)
    if not proj or not proj.Parent then return end
    if proj:IsA("BasePart") and proj.Velocity then
        local dir = (targetPos - proj.Position).Unit
        local spd = proj.Velocity.Magnitude
        if spd < 20 then spd = 100 end
        proj.Velocity = dir * spd
        proj.CFrame = CFrame.new(proj.Position, targetPos)
    end
end
RunService.Heartbeat:Connect(function()
    if not homingOn then return end
    local targetPos = getClosestEnemyPos()
    if not targetPos then return end
    for _,obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Velocity and obj.Velocity.Magnitude>30 and not obj:IsDescendantOf(char) and not tracked[obj] then
            tracked[obj]=true
            task.spawn(function()
                task.wait(0.05)
                if obj and obj.Parent then steerProjectile(obj,targetPos) end
                tracked[obj]=nil
            end)
        end
    end
end)

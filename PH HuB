-- 🎯 نظام التصويب التلقائي (Aim Assist)
-- ============================================================
local function GetSmartTarget()
    local bestTarget = nil
    local bestScore = -math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and not Settings.IgnoredPlayers[p.Name] and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (rootPart.Position - hrp.Position).Magnitude
                local score = (60 - dist) + (20 - (hum.Health / hum.MaxHealth) * 20)
                if score > bestScore then
                    bestScore = score
                    bestTarget = p
                end
            end
        end
    end
    return bestTarget
end

local function UpdateAim()
    if not Settings.AutoAimEnabled then return end
    local target = GetSmartTarget()
    if target and target.Character then
        local targetPos = target.Character:FindFirstChild("HumanoidRootPart").Position
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
        rootPart.CFrame = CFrame.new(rootPart.Position, Vector3.new(targetPos.X, rootPart.Position.Y, targetPos.Z))
    end
end


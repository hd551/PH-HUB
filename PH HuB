local teleOn = false
local function getNearestTeleportTarget()
    local nearest,nearestDist = nil,80
    for _,plr in pairs(Players:GetPlayers()) do
        if plr~=player and not ignored[plr.Name] and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (rootPart.Position - hrp.Position).Magnitude
                if dist < nearestDist then nearestDist=dist nearest=plr end
            end
        end
    end
    return nearest
end
local function getTeleportPosition(target)
    local c = target.Character
    if not c then return nil end
    local hand = c:FindFirstChild("RightHand") or c:FindFirstChild("Right Arm") or c:FindFirstChild("ArmR")
    if hand then return hand.Position end
    local head = c:FindFirstChild("Head")
    if head then return head.Position + Vector3.new(1.2,0,0) end
    local hrp = c:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position + Vector3.new(1.5,1,0) end
    return nil
end
local function doTeleport()
    if isTeleporting then return end
    local target = getNearestTeleportTarget()
    if not target then
        tpFloat.Text = "❌"
        tpFloat.BackgroundColor3 = Color3.fromRGB(200,0,0)
        task.wait(0.6)
        tpFloat.Text = "🔮\nTP"
        tpFloat.BackgroundColor3 = Color3.fromRGB(25,25,35)
        return
    end
    local pos = getTeleportPosition(target)
    if not pos then return end
    isTeleporting = true
    savedPos = rootPart.CFrame
    rootPart.CFrame = CFrame.new(pos)
    tpFloat.Text = "🔄"
    tpFloat.BackgroundColor3 = Color3.fromRGB(200,150,0)
    for ang=0,300,60 do
        local rad = math.rad(ang)
        local offset = Vector3.new(math.cos(rad)*2.5,0,math.sin(rad)*2.5)
        pcall(function() rootPart.CFrame = CFrame.new(pos+offset,pos) end)
        task.wait(0.012)
    end
    tpFloat.Text = "📍"
    tpFloat.BackgroundColor3 = Color3.fromRGB(0,200,0)
    task.wait(0.08)
    if savedPos then
        rootPart.CFrame = savedPos
        savedPos = nil
    end
    tpFloat.Text = "🔮\nTP"
    tpFloat.BackgroundColor3 = Color3.fromRGB(25,25,35)
    isTeleporting = false
end
telBtn.MouseButton1Click:Connect(function()

-- الأيم بوت
local function isVisible(targetPart)
    if not targetPart then return false end
    local origin = camera.CFrame.Position; local direction = targetPart.Position - origin
    if direction.Magnitude < 0.1 then return true end
    local raycastParams = RaycastParams.new(); raycastParams.FilterType = Enum.RaycastFilterType.Exclude; raycastParams.FilterDescendantsInstances = {player.Character, targetPart.Parent}; raycastParams.IgnoreWater = true
    return workspace:Raycast(origin, direction, raycastParams) == nil
end

local mouse = nil pcall(function() mouse = player:GetMouse() end)
local function getAimPosition()
    if mouse then return Vector2.new(mouse.X, mouse.Y) + Vector2.new(settings.aimOffsetX, settings.aimOffsetY)
    else return camera.ViewportSize/2 + Vector2.new(settings.aimOffsetX, settings.aimOffsetY) end
end

local function getClosestPlayerToMouse()
    local target, minDist = nil, settings.aimFOV; local aimPos = getAimPosition()
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            local hrp = v.Character.HumanoidRootPart; local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local dist = (Vector2.new(pos.X, pos.Y) - aimPos).Magnitude
                if dist < minDist and isVisible(hrp) then minDist = dist; target = hrp end
            end
        end
    end
    return target
end

RunService.RenderStepped:Connect(function()
    if settings.aimbotEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        local tgt = getClosestPlayerToMouse()
        if tgt then camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, tgt.Position), settings.aimSmoothness) end
    end
end)


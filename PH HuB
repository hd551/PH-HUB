-- ==================== التلبورت الذكي ====================
local function getHandPos(target)
    local char = target.Character
    if not char then return nil end
    local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm") or char:FindFirstChild("ArmR")
    if hand then return hand.Position end
    local head = char:FindFirstChild("Head")
    if head then return head.Position + Vector3.new(1.2, 0, 0) end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position + Vector3.new(1.5, 1, 0) end
    return nil
end

local function fastTeleport(pos)
    if rootPart and pos then
        rootPart.CFrame = CFrame.new(pos)
        return true
    end
    return false
end

local function performTeleport()
    if isTeleporting then return end
    isTeleporting = true
    
    local target = getSmartTarget()
    if not target then
        tpButton.Text = "❌"
        tpButton.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        showNotification("⚠️ No nearby player found", 1)
        task.wait(0.8)
        tpButton.Text = "🔮\nTP"
        tpButton.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        isTeleporting = false
        return
    end
    
    local handPos = getHandPos(target)
    if not handPos then
        tpButton.Text = "⚠️"
        tpButton.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
        showNotification("⚠️ Cannot find target position", 1)
        task.wait(0.8)
        tpButton.Text = "🔮\nTP"
        tpButton.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        isTeleporting = false
        return
    end
    
    -- حفظ المكان الأصلي
    savedPosition = rootPart.CFrame
    
    -- التلبورت الفوري
    fastTeleport(handPos)
    tpButton.Text = "🔄"
    tpButton.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
    
    -- اللف حول اللاعب (6 نقاط)
    for angle = 0, 300, 60 do
        local rad = math.rad(angle)
        local offset = Vector3.new(math.cos(rad) * 2.2, 0, math.sin(rad) * 2.2)
        local newPos = handPos + offset
        pcall(function() rootPart.CFrame = CFrame.new(newPos, handPos) end)
        task.wait(0.012)
    end
    
    -- العودة إلى المكان الأصلي
    tpButton.Text = "📍"
    tpButton.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    task.wait(0.08)
    if savedPosition then
        fastTeleport(savedPosition.Position)
        savedPosition = nil
    end
    
    tpButton.Text = "🔮\nTP"
    tpButton.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    isTeleporting = false
    

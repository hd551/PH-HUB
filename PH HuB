-- ============================================================
-- 🌀 نظام التلبورت الذكي + CD + منع السبام
-- ============================================================
local function GetHandPosition(targetPlayer)
    local char = targetPlayer.Character
    if not char then return nil end
    local hand = char:FindFirstChild("RightHand") or char:FindFirstChild("Right Arm") or char:FindFirstChild("ArmR")
    if hand then return hand.Position end
    local head = char:FindFirstChild("Head")
    if head then return head.Position + Vector3.new(1.2, 0, 0) end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then return hrp.Position + Vector3.new(1.8, 1.2, 0) end
    return nil
end

local function FastTeleport(position)
    if rootPart and position then
        rootPart.CFrame = CFrame.new(position)
    end
end

local function PerformTeleport()
    if isTeleporting then return end
    if Settings.TeleportCooldown then
        ShowNotification("⏳ التلبورت في انتظار (برودة)", Color3.fromRGB(255, 150, 0))
        return
    end
    
    -- نظام الكومبو
    if not CheckCombo("Teleport") then return end
    
    isTeleporting = true
    local target = GetSmartTarget()
    if not target then
        tpFloating.Text = "❌"
        tpFloating.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(0.5)
        tpFloating.Text = "🌀\nTP"
        tpFloating.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        isTeleporting = false
        return
    end
    
    local handPos = GetHandPosition(target)
    if not handPos then
        tpFloating.Text = "⚠️"
        tpFloating.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
        task.wait(0.5)
        tpFloating.Text = "🌀\nTP"
        tpFloating.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
        isTeleporting = false
        return
    end
    
    TeleportPosition = rootPart.CFrame
    FastTeleport(handPos)
    tpFloating.Text = "🌀"
    tpFloating.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
    
    -- دوران سريع حول الهدف (لفة واحدة سريعة جداً)
    for ang = 0, 300, 60 do
        local rad = math.rad(ang)
        local offset = Vector3.new(math.cos(rad) * 2.5, 0, math.sin(rad) * 2.5)
        pcall(function() rootPart.CFrame = CFrame.new(handPos + offset, handPos) end)
        task.wait(0.008)
    end
    
    tpFloating.Text = "📍"
    tpFloating.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
    task.wait(0.05)
    
    if TeleportPosition then
        FastTeleport(TeleportPosition.Position)
        TeleportPosition = nil
    end
    
    tpFloating.Text = "🌀\nTP"
    tpFloating.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    isTeleporting = false
    
    -- تطبيق Cooldown لمدة ثانية واحدة (لتجنب السبام)
    Settings.TeleportCooldown = true
    task.delay(1.2, function() Settings.TeleportCooldown = false end)
end


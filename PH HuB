-- ==================== ESP (بدون تجمّد) ====================
local espOn = false

local function clearESP()
    for _, data in pairs(espItems) do
        pcall(function()
            if data.name then data.name:Destroy() end
            if data.bar then data.bar:Destroy() end
        end)
    end
    espItems = {}
end

local function updateESP()
    if not espOn then
        clearESP()
        return
    end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr == player or ignoredPlayers[plr.Name] then
            if espItems[plr] then
                pcall(function()
                    espItems[plr].name:Destroy()
                    espItems[plr].bar:Destroy()
                end)
                espItems[plr] = nil
            end
        else
            local char = plr.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.2, 0))
                if onScreen and pos.Z > 0 then
                    if not espItems[plr] then
                        local name = Instance.new("TextLabel")
                        name.Size = UDim2.new(0, 160, 0, 24)
                        name.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                        name.BackgroundTransparency = 0.5
                        name.TextColor3 = Color3.fromRGB(255, 255, 255)
                        name.TextSize = 12
                        name.Font = Enum.Font.GothamBold
                        name.Parent = gui
                        Instance.new("UICorner", name).CornerRadius = UDim.new(0, 6)
                        
                        local bar = Instance.new("Frame")
                        bar.Size = UDim2.new(0, 70, 0, 6)
                        bar.BackgroundColor3 = Color3.fromRGB(0, 200, 0)
                        bar.BorderSizePixel = 0
                        bar.Parent = gui
                        Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
                        
                        espItems[plr] = {name = name, bar = bar}
                    end
                    local hp = hum.Health / hum.MaxHealth
                    espItems[plr].name.Position = UDim2.new(0, pos.X - 80, 0, pos.Y - 45)
                    espItems[plr].name.Text = "[" .. plr.Name .. "]"
                    espItems[plr].name.Visible = true
                    
                    espItems[plr].bar.Size = UDim2.new(0, 70 * hp, 0, 6)
                    espItems[plr].bar.Position = UDim2.new(0, pos.X - 35, 0, pos.Y - 20)
                    espItems[plr].bar.BackgroundColor3 = Color3.fromRGB(0, 255, 0):Lerp(Color3.fromRGB(255, 0, 0), 1 - hp)
                    espItems[plr].bar.Visible = true
                else
                    if espItems[plr] then
                        espItems[plr].name.Visible = false
                        espItems[plr].bar.Visible = false
                    end
                end
            else
                if espItems[plr] then
                    pcall(function()
                        espItems[plr].name:Destroy()
                        espItems[plr].bar:Destroy()
                    end)
                    espItems[plr] = nil
                end
            end
        end
    end
end


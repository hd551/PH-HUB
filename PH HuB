local speedOn = false
local speedVal = 50

local function setSpeed()
    if speedOn and humanoid then
        humanoid.WalkSpeed = speedVal
        -- طريقة بديلة لبعض الألعاب العنيدة
        if rootPart and rootPart.AssemblyLinearVelocity then
            local vel = rootPart.AssemblyLinearVelocity
            if vel.Magnitude < speedVal then
                rootPart.AssemblyLinearVelocity = vel.Unit * speedVal
            end
        end
    end
end

